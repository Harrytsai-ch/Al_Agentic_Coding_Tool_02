<div id="app" data-order-id="<%= orderId %>" data-payment-result="<%= paymentResult %>" v-cloak>
  <div class="d-flex align-items-center gap-2 mb-4">
    <a href="/orders" class="btn btn-link link-secondary p-0 text-decoration-none"><i class="bi bi-arrow-left"></i></a>
    <h1 class="h3 mb-0">訂單詳情</h1>
  </div>

  <div v-if="loading" class="loader">
    <div class="spinner-border text-brand" role="status"><span class="visually-hidden">載入中</span></div>
  </div>

  <template v-else-if="order">
    <div class="row g-4">
      <div class="col-lg-8">
        <!-- Payment Result Alert -->
        <div
          v-if="paymentResult && paymentMessages[paymentResult]"
          class="p-3 rounded-3 mb-4 small d-flex align-items-center gap-2"
          :class="paymentMessages[paymentResult].cls">
          <i class="bi bi-info-circle-fill"></i>{{ paymentMessages[paymentResult].text }}
        </div>

        <!-- Order Info -->
        <div class="surface shadow-soft p-4 mb-4">
          <div class="d-flex align-items-start justify-content-between flex-wrap gap-2">
            <div>
              <p class="small text-muted-2 mb-1"><i class="bi bi-receipt me-1"></i>訂單編號：<span class="text-dark fw-medium">{{ order.order_no }}</span></p>
              <p class="small text-muted-2 mb-1">建立日期：{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
              <p v-if="order.paid_at" class="small text-muted-2 mb-1">付款時間：{{ order.paid_at }}</p>
              <p v-if="order.payment_type" class="small text-muted-2 mb-0">付款方式：{{ order.payment_type }}</p>
            </div>
            <span
              class="badge rounded-pill"
              :class="statusMap[order.status]?.cls || 'bg-secondary-subtle text-secondary-emphasis'">
              {{ statusMap[order.status]?.label || order.status }}
            </span>
          </div>
        </div>

        <!-- Recipient Info -->
        <div class="surface shadow-soft p-4 mb-4">
          <h2 class="h6 mb-3"><i class="bi bi-geo-alt text-brand me-1"></i>收件資訊</h2>
          <div class="row g-2 small">
            <div class="col-12"><span class="text-muted-2">收件人：</span><span class="text-dark">{{ order.recipient_name }}</span></div>
            <div class="col-12"><span class="text-muted-2">Email：</span><span class="text-dark">{{ order.recipient_email }}</span></div>
            <div class="col-12"><span class="text-muted-2">地址：</span><span class="text-dark">{{ order.recipient_address }}</span></div>
          </div>
        </div>

        <!-- Order Items -->
        <div class="surface shadow-soft p-4 mb-4">
          <h2 class="h6 mb-3"><i class="bi bi-box-seam text-brand me-1"></i>商品明細</h2>
          <div class="table-responsive">
            <table class="table table-clean align-middle small mb-0">
              <thead>
                <tr>
                  <th>商品名稱</th>
                  <th class="text-end">單價</th>
                  <th class="text-end">數量</th>
                  <th class="text-end">小計</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="item in order.items" :key="item.id">
                  <td class="text-dark">{{ item.product_name }}</td>
                  <td class="text-end text-muted-2">NT$ {{ item.product_price.toLocaleString() }}</td>
                  <td class="text-end text-muted-2">{{ item.quantity }}</td>
                  <td class="text-end fw-medium text-dark">NT$ {{ (item.product_price * item.quantity).toLocaleString() }}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Side: total + payment -->
      <div class="col-lg-4">
        <div class="surface shadow-soft p-4 summary-card">
          <h2 class="h6 mb-3">付款資訊</h2>
          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="fw-semibold text-dark">應付總計</span>
            <span class="summary-total">NT$ {{ order.total_amount.toLocaleString() }}</span>
          </div>

          <!-- Payment verification status -->
          <div v-if="verifying" class="d-flex align-items-center gap-2 small text-muted-2 mb-3">
            <div class="spinner-border spinner-border-sm text-brand" role="status"></div>
            <span>{{ verifyMessage || '正在向綠界查詢付款結果…' }}</span>
          </div>
          <div v-else-if="verifyMessage && order.status === 'pending'" class="p-3 rounded-3 mb-3 small bg-warning-subtle text-warning-emphasis">
            {{ verifyMessage }}
          </div>

          <!-- Payment Buttons -->
          <div v-if="order.status === 'pending'" class="d-grid gap-2">
            <button
              @click="payWithEcpay"
              :disabled="paying || verifying"
              class="btn btn-cta btn-lg">
              <i class="bi bi-credit-card-2-front me-2"></i>{{ paying ? '準備中...' : '前往綠界付款' }}
            </button>
            <button
              @click="manualVerify"
              :disabled="paying || verifying"
              class="btn btn-outline-brand">
              <i class="bi bi-arrow-clockwise me-1"></i>重新查詢付款結果
            </button>
          </div>
          <div v-else-if="order.status === 'paid'" class="notice notice-success">
            <i class="bi bi-check-circle-fill"></i>此訂單已完成付款
          </div>
          <div v-else class="notice" style="background: #FCEBE7; color: var(--danger);">
            <i class="bi bi-x-circle-fill"></i>此訂單付款未完成
          </div>
        </div>
      </div>
    </div>
  </template>
</div>
